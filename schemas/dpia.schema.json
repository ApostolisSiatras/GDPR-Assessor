          "purpose",
          "lawful_basis",
          "categories_of_data",
          "data_subjects",
          "retention",
          "recipients",
          "transfers",
          "security_measures"
        ],
        "properties": {
          "name": {"type": "string"},
          "purpose": {"type": "string"},
          "lawful_basis": {"type": "string"},
          "categories_of_data": {
            "type": "array",
            "items": {"type": "string"}
          },
          "data_subjects": {
            "type": "array",
            "items": {"type": "string"}
          },
          "retention": {"type": "string"},
          "recipients": {
            "type": "array",
            "items": {"type": "string"}
          },
          "transfers": {
            "type": "array",
            "items": {"type": "string"}
          },
          "security_measures": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
